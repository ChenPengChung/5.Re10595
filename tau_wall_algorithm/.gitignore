# ── Pipeline output (large data) ──
Output/

# ── Input data files (user-provided, large) ──
Input/*.vtk
Input/*.dat
# Keep metadata and helper scripts
!Input/*_metadata.dat
!Input/generate_metadata.py

# ── Verify output images (regenerable) ──
verify/*.png

# ── Python ──
__pycache__/
*.pyc
*.pyo

# ── Editor / IDE ──
.vscode/
.idea/

# ── OS ──
Thumbs.db
.DS_Store

# ── Claude Code ──
.claude/
