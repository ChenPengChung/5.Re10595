# =============================================================================
#  .gitignore  —  Re1400 LBM 模擬專案
#  原則：原始碼 / 腳本 / 參考資料 追蹤；模擬輸出 / 續跑檔 / 影片 / 日誌 忽略
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 編譯產物 (compiled binaries)
# -----------------------------------------------------------------------------
a.out
a.out.*
*.o
*.obj

# -----------------------------------------------------------------------------
# 2. Slurm / HPC 執行時產物
# -----------------------------------------------------------------------------
slurm_*.log
slurm_*.err
slurm-*.out
*.slurm.log

# -----------------------------------------------------------------------------
# 3. Dispatcher / Chain 執行鎖與狀態檔
# -----------------------------------------------------------------------------
.run.lock
DISPATCHER_ACTIVE
chain_code/**/*.lock
chain_code/chain.log

# -----------------------------------------------------------------------------
# 4. 續跑檔 (restart / checkpoint)
# -----------------------------------------------------------------------------
restart/

# -----------------------------------------------------------------------------
# 5. 模擬輸出 —  result/ 下的原始資料
# -----------------------------------------------------------------------------
# 所有 MPI 分塊 / 合併輸出 (bin / vtk / 瞬時 dat)
result/*.bin
result/*.vtk
result/*.vti
result/*.vtu
result/*.pvtu
result/*.pvd
result/*.h5
result/*.tec
result/0_force.dat
result/velocity_merged_*.*
result/velocity_*_Final.*

# 但保留 benchmark 參考資料 與 Python 分析腳本
!result/benchmark/
!result/benchmark/**
!result/*.py
!result/*.cpp
!result/*.png

# -----------------------------------------------------------------------------
# 6. Animation / 影片 / 圖框
# -----------------------------------------------------------------------------
animation/*.mp4
animation/*.mp4.lock
animation/*.mp4.tmp.mp4
animation/*.tmp.mp4
animation/.mp4list_*.concat.txt
animation/.mp4list_*.txt
animation/anim_log.txt
animation/png_frames/
animation/frames/
animation/*.png
animation/*.jpg

# animation 資料夾下的 slurm 腳本副本 (由 chain 動態複製的)
animation/jobscript_chain.slurm.*

# -----------------------------------------------------------------------------
# 7. 模擬過程產生的診斷 / 統計 檔
# -----------------------------------------------------------------------------
gilbm_metrics_full.dat
meshX.DAT
meshYZ.DAT

# 根目錄下常見模擬輸出 (不影響已追蹤的 .h / .cu / .py)
/*.bin
/*.vtk
/*.vti
/*.vtu

# -----------------------------------------------------------------------------
# 8. 編輯器 / 系統暫存
# -----------------------------------------------------------------------------

.idea/
*.swp
*.swo
*~
.DS_Store
**/.DS_Store
._*
**/._*
Thumbs.db

# Claude Code CLI 本機設定（含本地權限 / 排程鎖，不應進版控）
.claude/
**/.claude/

# -----------------------------------------------------------------------------
# 9. Python 暫存
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# 10. 雜項暫存 / 批次產生
# -----------------------------------------------------------------------------
*.tmp
*.bak
nohup.out
core
core.*

# simulation outputs
Ustar_Force_record.dat
timing_log.dat
checkrho.dat
png_frames/
result/monitor_convergence_*.{pdf,png}

# simulation outputs
Ustar_Force_record.dat
timing_log.dat
checkrho.dat
png_frames/
result/monitor_convergence_*.{pdf,png}
